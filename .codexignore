# .codexignore — Files Codex should not read or modify
# Format: one pattern per line. Follows .gitignore syntax.

# Dependencies
node_modules/
.venv/
__pycache__/
target/
.cargo/

# Build outputs
dist/
build/
out/
.next/
.nuxt/

# Lock files (read-only reference — never edit directly)
package-lock.json
yarn.lock
pnpm-lock.yaml
Cargo.lock
poetry.lock
Pipfile.lock

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Codex internals
.codex/cocoindex/
brain/tasks/.discovery.env
brain/tasks/session-logs/

# Secrets / credentials
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
secrets/
credentials/

# Large binary assets
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
*.pdf
*.zip
*.tar.gz
*.wasm
