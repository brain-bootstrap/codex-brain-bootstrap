{
  "_comment": "Codex lifecycle hooks — requires [features] codex_hooks = true in .codex/config.toml",
  "_docs": "https://developers.openai.com/codex/hooks",

  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/session-start.sh",
            "statusMessage": "Loading brain context and task state",
            "timeout": 10
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/prompt-guard.sh",
            "statusMessage": "Scanning prompt for accidentally pasted secrets",
            "timeout": 5
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/config-protection.sh",
            "statusMessage": "Checking config protection policy",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/terminal-safety-gate.sh",
            "statusMessage": "Checking terminal safety policy",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/pre-commit-quality.sh",
            "statusMessage": "Running pre-commit quality gate",
            "timeout": 10
          }
        ]
      }
    ],

    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/permission-audit.sh",
            "statusMessage": "Logging permission request",
            "timeout": 5
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/post-bash-review.sh",
            "statusMessage": "Reviewing Bash output",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/edit-accumulator.sh",
            "statusMessage": "Recording edited file for batch processing",
            "timeout": 5
          }
        ]
      }
    ],

    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/subagent-stop.sh",
            "statusMessage": "Logging subagent completion",
            "timeout": 5
          }
        ]
      }
    ],

    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/permission-denied.sh",
            "statusMessage": "Logging permission denial",
            "timeout": 5
          }
        ]
      }
    ],

    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/pre-compact.sh",
            "statusMessage": "Preserving context before compaction",
            "timeout": 10
          }
        ]
      }
    ],

    "OnCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/on-compact.sh",
            "statusMessage": "Re-injecting context after compaction",
            "timeout": 5
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/tdd-loop-check.sh",
            "statusMessage": "Checking for failing tests",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/exit-nudge.sh",
            "statusMessage": "Running exit checklist",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env bash \"$(git rev-parse --show-toplevel 2>/dev/null || echo .)\"/.codex/hooks/warn-missing-test.sh",
            "statusMessage": "Checking for source files without tests (strict profile)",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
